{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "Information about a badminton player",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["包月", "包半月", "按次"] },
        "defaultFee": { "type": "number" },
        "isFunder": { "type": "boolean" }
      },
      "required": ["id", "name", "type", "defaultFee", "isFunder"]
    },
    "Period": {
      "title": "Settlement Period",
      "description": "A financial settlement period for the club",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "courtCost": { "type": "number" },
        "sessions": { "type": "array" },
        "funderIds": { "type": "array" },
        "playerConfigs": { "type": "array" }
      },
      "required": ["id", "name", "startDate", "endDate", "courtCost", "sessions", "funderIds"]
    }
  },
  "firestore": {
    "players/{playerId}": {
      "schema": { "$ref": "#/entities/Player" },
      "description": "Collection of all players in the club"
    },
    "periods/{periodId}": {
      "schema": { "$ref": "#/entities/Period" },
      "description": "Collection of all club history periods"
    }
  }
}
