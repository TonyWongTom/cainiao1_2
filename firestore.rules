rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Helper Definitions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Players Collection ---
    match /players/{playerId} {
      // Must be signed in AND verified to access anything
      allow get: if isVerified() && isValidId(playerId);
      allow list: if isVerified();
      
      // Validation helper
      function isValidPlayer(data) {
        return data.keys().hasAll(['id', 'name', 'type', 'defaultFee', 'isFunder']) 
          && data.keys().size() == 5
          && data.id is string && data.id.size() <= 64
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.type in ['包月', '包半月', '按次']
          && data.defaultFee is number
          && data.isFunder is bool;
      }

      allow create: if isVerified() && isValidId(playerId) && isValidPlayer(incoming()) && incoming().id == playerId;
      
      allow update: if isVerified() && isValidId(playerId) && isValidPlayer(incoming()) 
        && incoming().id == existing().id 
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'type', 'defaultFee', 'isFunder'])
        );
      
      allow delete: if isVerified() && isValidId(playerId);
    }

    // --- Periods Collection ---
    match /periods/{periodId} {
      allow get: if isVerified() && isValidId(periodId);
      allow list: if isVerified();

      function isValidPeriod(data) {
        return data.keys().hasAll(['id', 'name', 'startDate', 'endDate', 'courtCost', 'sessions', 'funderIds'])
          && (data.keys().size() == 7 || (data.keys().size() == 8 && data.keys().hasAll(['playerConfigs'])))
          && data.id is string && data.id.size() <= 64
          && data.name is string && data.name.size() > 0 && data.name.size() <= 200
          && data.startDate is string && data.startDate.size() <= 64
          && data.endDate is string && data.endDate.size() <= 64
          && data.courtCost is number
          && data.sessions is list && data.sessions.size() <= 200
          && data.funderIds is list && data.funderIds.size() <= 300
          && (!('playerConfigs' in data) || (data.playerConfigs is list && data.playerConfigs.size() <= 300));
      }

      allow create: if isVerified() && isValidId(periodId) && isValidPeriod(incoming()) && incoming().id == periodId;

      allow update: if isVerified() && isValidId(periodId) && isValidPeriod(incoming())
        && incoming().id == existing().id
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'startDate', 'endDate', 'courtCost', 'sessions', 'funderIds', 'playerConfigs'])
        );

      allow delete: if isVerified() && isValidId(periodId);
    }

    // --- Test Collection (for connection check) ---
    match /test/connection {
      allow get: if true; // Connection check does not need to block
    }
  }
}
